<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#FFF3E0"
            app:cardCornerRadius="36dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="🔥"
                android:textSize="36sp" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/lexenddeca"
            android:text="Info Pembakaran"
            android:textColor="#212121"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_dialog_harian"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/lexenddeca"
            android:text="Hari ini kamu sudah membakar 30 Kkal."
            android:textAlignment="center"
            android:textColor="#757575"
            android:textSize="14sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="#E3F2FD"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="#90CAF9"
            app:strokeWidth="1dp">

            <TextView
                android:id="@+id/tv_dialog_total"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/lexenddeca"
                android:padding="16dp"
                android:text="Total Usahamu: 30 Kkal terbakar sejauh ini.\n\nEfek Gamifikasi: Berat badan karaktermu telah menyusut sebanyak 0.3 Kg! Teruslah konsisten untuk mencapai tubuh ideal."
                android:textAlignment="center"
                android:textColor="#1565C0"
                android:textSize="13sp"
                android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_dialog_tutup"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:fontFamily="@font/lexenddeca"
            android:text="Tutup &amp; Lanjutkan"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#4FA5E2"
            app:cornerRadius="25dp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>